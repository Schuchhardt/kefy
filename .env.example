# Supabase (server-only — never expose to client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT (genera un string aleatorio seguro, mín. 32 caracteres)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# AI — Content generation
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENAI_API_KEY=sk-your-openai-key

# Zernio — Social media publishing
ZERNIO_API_KEY=your-zernio-api-key
ZERNIO_API_URL=https://zernio.com/api/v1

# Autopilot cron (genera con: openssl rand -hex 32)
AUTOPILOT_CRON_SECRET=your-cron-secret

# Resend
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Kefy <no-reply@email.kefy.app>

# Firecrawl
FIRECRAWL_API_KEY=your-firecrawl-api-key

# Zernio webhook secret (genera con: openssl rand -hex 32)
ZERNIO_WEBHOOK_SECRET=your-zernio-webhook-secret

# Stripe — Billing & subscriptions
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_STARTER=price_your-starter-price-id
STRIPE_PRICE_PRO=price_your-pro-price-id
STRIPE_PRICE_BUSINESS=price_your-business-price-id
# Zernio debug (opcional — pone '1' para logs detallados en desarrollo)
# ZERNIO_DEBUG=1

# Mux — Video hosting y reproducción
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret

# App URL (usada en OAuth callbacks; omitir en dev, Next.js usa el origin de la request)
NEXT_PUBLIC_APP_URL=https://kefy.app

# Auth — TTL del access token en horas (por defecto: 24)
# ACCESS_TOKEN_TTL_HOURS=24
